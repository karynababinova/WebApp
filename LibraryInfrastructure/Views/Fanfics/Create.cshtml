@model LibraryInfrastructure.Models.WorkFormViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Створити твір";
    var tags = ViewData["Tags"] as List<SelectListItem> ?? new List<SelectListItem>();
}

<section class="form-shell">
    <h1>Створити новий твір</h1>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-msg"></div>

        <label asp-for="Title"></label>
        <input asp-for="Title" />
        <span asp-validation-for="Title" class="validation-msg"></span>

        <label asp-for="Description"></label>
        <textarea asp-for="Description" rows="6"></textarea>
        <span asp-validation-for="Description" class="validation-msg"></span>

        <label asp-for="ContentRatingId"></label>
        <select asp-for="ContentRatingId" asp-items="ViewBag.ContentRatingId">
            <option value="">Не вказано</option>
        </select>

        <label asp-for="SelectedTagIds"></label>
        <select asp-for="SelectedTagIds" asp-items="tags" multiple size="8"></select>
        <small>Утримуйте Ctrl/Cmd для вибору кількох тегів.</small>

        <hr />
        <h2>Перший розділ</h2>

        <label asp-for="FirstChapterTitle"></label>
        <input asp-for="FirstChapterTitle" />
        <span asp-validation-for="FirstChapterTitle" class="validation-msg"></span>

        <label asp-for="FirstChapterContent"></label>
        <textarea asp-for="FirstChapterContent" rows="10"></textarea>
        <span asp-validation-for="FirstChapterContent" class="validation-msg"></span>

        <div class="actions-row">
            <button type="submit" class="btn-simple">Опублікувати</button>
            <a asp-action="Index" class="btn-simple ghost">Скасувати</a>
        </div>
    </form>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
