<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Архів Творів</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LibraryInfrastructure.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container">
            <nav class="top-nav">
                <a class="brand" asp-controller="Home" asp-action="Index">Архів Творів</a>
                <div class="menu-left">
                    <a asp-controller="Home" asp-action="Index">Аналітика</a>
                    <a asp-controller="Fanfics" asp-action="Index">Твори</a>
                    <a asp-controller="Tags" asp-action="Index">Теги</a>
                </div>
                <div class="menu-right">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-controller="Account" asp-action="Users">Користувачі</a>
                        }
                        @if (User.IsInRole("Author") || User.IsInRole("Admin"))
                        {
                            <a asp-controller="Fanfics" asp-action="Create">Додати твір</a>
                        }
                        <a asp-controller="Account" asp-action="Bookmarks">Закладки</a>
                        <a asp-controller="Account" asp-action="Profile">Профіль</a>
                        <span class="user-name">@User.Identity.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="inline-form">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn-link-plain">Вийти</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login">Увійти</a>
                        <a asp-controller="Account" asp-action="Register">Реєстрація</a>
                    }
                </div>
            </nav>
        </div>
    </header>

    <main class="container page-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">&copy; 2026 Архів Творів</div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
